SUPABASE_URL=
SUPABASE_SERVICE_KEY=
PORT=4000
DEPLOYMENT_MODE=local

# Pick at least one of these two options:

# Option A — local model, free, offline, fastest for real practice
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Option B — a cloud provider (get a free key, takes ~2 minutes):
#   Groq (recommended — generous free tier, fast): https://console.groq.com/keys
#   OpenAI: https://platform.openai.com/api-keys
#   Gemini: https://aistudio.google.com/apikey
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# A random secret used to encrypt any personal API keys saved in Settings.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_ENCRYPTION_SECRET=
